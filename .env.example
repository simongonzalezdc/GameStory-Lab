# GameForge Studio Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=postgresql://gameforge:gameforge_dev_password@localhost:5432/gameforge

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_URL=redis://localhost:6379

# ============================================================================
# AI Provider Configuration (November 2025 - Latest Models)
# ============================================================================

# OpenRouter (Cloud AI - Optional)
# Provides access to DeepSeek V3, Qwen 2.5 72B, GPT-4, Claude, Gemini
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Google Gemini (Cloud AI - Optional)
# Used for consistency validation with 1M context window
# Get your key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaSy-your-key-here

# Ollama (Local AI - Free & Unlimited)
# November 2025 Recommended Models (optimized for Mac M4 16GB):
#   - qwen3:30b-a3b (MoE: 30B quality, 3B memory - BEST!)
#   - phi4:14b (9.8T tokens, excellent reasoning)
#   - qwen3-coder:7b (best creative writing)
#   - qwen3:7b (best structured JSON)
#   - deepseek-r1:8b (advanced reasoning)
#   - llama4:8b (lightweight, versatile)
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Pull models: ollama pull qwen3:30b-a3b && ollama pull phi4:14b
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================================
# Application Configuration
# ============================================================================
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# ============================================================================
# Rate Limiting Configuration
# ============================================================================
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000

# ============================================================================
# Cost Protection
# ============================================================================
AI_COST_LIMIT_PER_HOUR_USD=5.00
