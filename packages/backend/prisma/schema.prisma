// GameForge Studio Database Schema
// Based on technical specification v1.0.0

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  projects Project[]

  @@map("users")
}

model Project {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  name      String   @db.VarChar(255)
  genre     String?  @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user                User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions            Version[]
  chatSessions        ChatSession[]
  assistantProposals  AssistantProposal[]

  @@index([userId])
  @@index([userId, updatedAt])
  @@index([createdAt])
  @@map("projects")
}

model Version {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  version   Int      @default(1)
  title     String?  @db.VarChar(500)
  mechanics Json     @default("{}") @db.JsonB
  lore      Json     @default("{}") @db.JsonB
  metadata  Json     @default("{}") @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  project             Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  aiGenerations       AiGeneration[]
  validationResults   ValidationResult[]
  assistantProposals  AssistantProposal[]

  @@index([projectId])
  @@index([projectId, createdAt])
  @@index([projectId, version])
  @@index([mechanics(ops: JsonbPathOps)], type: Gin)
  @@index([lore(ops: JsonbPathOps)], type: Gin)
  @@map("concepts")
}

model AiGeneration {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conceptId   String   @map("concept_id") @db.Uuid
  taskType    String   @map("task_type") @db.VarChar(50)
  modelUsed   String   @map("model_used") @db.VarChar(100)
  prompt      String   @db.Text
  response    String   @db.Text
  tokensUsed  Int?     @map("tokens_used")
  costUsd     Decimal? @map("cost_usd") @db.Decimal(10, 6)
  durationMs  Int?     @map("duration_ms")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  version Version @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@index([conceptId])
  @@index([taskType])
  @@index([conceptId, createdAt])
  @@index([taskType, createdAt])
  @@map("ai_generations")
}

model ValidationResult {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conceptId  String   @map("concept_id") @db.Uuid
  ruleName   String   @map("rule_name") @db.VarChar(100)
  severity   String   @db.VarChar(20)
  confidence Decimal  @db.Decimal(3, 2)
  message    String   @db.Text
  suggestion String?  @db.Text
  dismissed  Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  version Version @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@index([conceptId])
  @@index([severity])
  @@index([conceptId, dismissed])
  @@index([conceptId, severity])
  @@index([dismissed, severity])
  @@map("validation_results")
}

model ChatSession {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId  String   @map("project_id") @db.Uuid
  type       String   @db.VarChar(50) @default("project")
  targetId   String?  @map("target_id") @db.Uuid
  metadata   Json     @default("{}") @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]
  proposals AssistantProposal[]

  @@index([projectId])
  @@index([projectId, type])
  @@map("chat_sessions")
}

model ChatMessage {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId  String   @map("session_id") @db.Uuid
  role       String   @db.VarChar(20)
  content    String   @db.Text
  metadata   Json     @default("{}") @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("chat_messages")
}

model AssistantProposal {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId   String   @map("session_id") @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  conceptId   String?  @map("concept_id") @db.Uuid
  proposalType String  @map("proposal_type") @db.VarChar(50)
  status      String   @db.VarChar(20) @default("pending")
  payload     Json     @db.JsonB
  changeLog   Json     @default("{}") @map("change_log") @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  resolvedAt  DateTime? @map("resolved_at") @db.Timestamptz

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  concept Version?    @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([projectId])
  @@index([projectId, status])
  @@map("assistant_proposals")
}
