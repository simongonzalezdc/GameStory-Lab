# Local Storage
DATABASE_PATH=./data/assets.db
STORAGE_PATH=./data/assets

# AI Providers (Optional - Ollama works without API keys!)
OPENROUTER_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# Ollama (Local AI) - Recommended for privacy & no API costs
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_ENABLED=true

# Optional: Additional AI Providers
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
GLM_API_KEY=

# App Settings
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
ENVIRONMENT=development
LOG_LEVEL=INFO
